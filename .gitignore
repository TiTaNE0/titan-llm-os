# Obsidian per-machine state
.obsidian/
*.sync

# macOS metadata
**/.DS_Store
.DS_Store

# Editor / IDE per-machine state
.idea/
.vscode/

# Generated / transient runtime artifacts
# Telemetry JSONL is the canonical audit trail and IS committed.
# CSV reports are derived from JSONL and can be regenerated by /metrics.
04_Logs/Telemetry/reports/*.csv

# Macro checkpoints are per-session resumable state, not history.
# (.gitkeep stays so the directory is tracked.)
04_Logs/Checkpoints/*.json

# Video binaries (reproducible from scripts; not in git)
05_Content/modules/video/renders/*.mp4
05_Content/modules/video/renders/*.mov
05_Content/modules/video/sources/*.mp4
05_Content/modules/video/sources/*.mov
05_Content/modules/video/sources/*.wav
05_Content/modules/video/sources/*.mp3

# Temp / swap
*.tmp
*.bak
*.swp
*~

# ============================================================
# Personal content (Path A cleanup, 2026-05-08)
# Framework files (kernel, templates, READMEs, protocols) stay tracked.
# Path B (extract framework to publishable repo, no-history-leak) is a backlog task.
# ============================================================

# Personal projects (framework keeps its own self-passport only)
01_Projects/*
!01_Projects/TiTan_LLM_OS.md

# All Kanban boards (project-specific + personal kernel work history)
*_Board.md

# Personal task workspace + archives
02_Tasks/
99_Archive/

# Personal session logs (markdown + telemetry + errors).
# Structure dirs are anchored by .gitkeep which stays tracked.
04_Logs/*.md
04_Logs/Telemetry/*.jsonl
04_Logs/Errors/*.md
04_Logs/Delegations/

# Personal intake + project research
00_Inbox/
06_Research/

# Auto-generated index (regenerated by /update_index)
Internal_Index.md

# Synthesized memory (output of /synthesize — personal compression of personal logs)
03_Brain/Weekly_Synthesis/*.md
03_Brain/Weekly_Synthesis/*.json
03_Brain/Weekly_Synthesis/*.jsonl
03_Brain/Weekly_Synthesis/archive/

# Personal content + assets
05_Content/01_Content_Ideas.md
05_Content/02_Content_Calendar.md
05_Content/03_Drafts/*.md
!05_Content/03_Drafts/README.md
05_Content/04_Published/
05_Content/05_Assets/

# Voice files are personal (the protocol + README are framework)
05_Content/personalization/voice_*.md

# Module-specific personal tactics + drift records
# (READMEs and templates/ stay tracked as framework)
05_Content/modules/*/strategy.md
05_Content/modules/*/failure_log.md
05_Content/modules/*/lessons_log.md
